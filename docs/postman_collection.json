          "name": "Inventory Status",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{librarianToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/reports/inventory-status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "reports", "inventory-status"]
            }
          }
        },
        {
          "name": "Most Borrowed Books",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{librarianToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/reports/most-borrowed-books",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "reports", "most-borrowed-books"]
            }
          }
        },
        {
          "name": "Active Members",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{librarianToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/reports/active-members",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "reports", "active-members"]
            }
          }
        },
        {
          "name": "Overdue Report",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{librarianToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/reports/overdue-records",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "reports", "overdue-records"]
            }
          }
        }
      ]
    }
  ]
}
