{
  "info": {
    "name": "Library Management System API",
    "description": "Postman collection for the internship Library Management System backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "librarianToken",
      "value": ""
    },
    {
      "key": "memberToken",
      "value": ""
    },
    {
      "key": "memberId",
      "value": ""
    },
    {
      "key": "categoryId",
      "value": ""
    },
    {
      "key": "bookId",
      "value": ""
    },
    {
      "key": "borrowRecordId",
      "value": ""
    },
    {
      "key": "notificationId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login Librarian",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('librarianToken', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"aayush.kr0804@gmail.com\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        },
        {
          "name": "Login Member",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('memberToken', json.token);",
                  "pm.collectionVariables.set('memberId', json.data.user._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"member@example.com\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        },
        {
          "name": "Current Profile",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{memberToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Create Category",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('categoryId', json.data.category._id);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{librarianToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Reference\",\n  \"description\": \"Reference books and exam material\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/categories",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "categories"]
            }
          }
        },
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/categories",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "categories"]
            }
          }
        }
      ]
    },
    {
      "name": "Books",
      "item": [
        {
          "name": "Create Book",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('bookId', json.data.book._id);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{librarianToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Node.js Design Patterns\",\n  \"isbn\": \"9781839214110\",\n  \"author\": \"Mario Casciaro\",\n  \"category\": \"{{categoryId}}\",\n  \"publisher\": \"Packt\",\n  \"publishedYear\": 2020,\n  \"totalCopies\": 3,\n  \"shelfLocation\": \"T-10\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/books",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "books"]
            }
          }
        },
        {
          "name": "List Books",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/books?availability=available",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "books"],
              "query": [
                {
                  "key": "availability",
                  "value": "available"
                }
              ]
            }
          }
        },
        {
          "name": "Check Availability",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{memberToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/borrows/availability/{{bookId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "borrows", "availability", "{{bookId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Borrowing",
      "item": [
        {
          "name": "Borrow Book as Member",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('borrowRecordId', json.data.borrowRecord._id);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{memberToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notes\": \"Borrowed through Postman\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/borrows/{{bookId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "borrows", "{{bookId}}"]
            }
          }
        },
        {
          "name": "Return Book",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{memberToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notes\": \"Returned in good condition\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/borrows/return/{{borrowRecordId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "borrows", "return", "{{borrowRecordId}}"]
            }
          }
        },
        {
          "name": "Borrowing History",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{memberToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/borrows/history",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "borrows", "history"]
            }
          }
        },
        {
          "name": "Overdue Records",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{librarianToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/borrows/overdue",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "borrows", "overdue"]
            }
          }
        }
      ]
    },
    {
      "name": "Members",
      "item": [
        {
          "name": "List Members",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{librarianToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/members",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "members"]
            }
          }
        },
        {
          "name": "My Borrow History",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{memberToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/members/me/history",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "members", "me", "history"]
            }
          }
        },
        {
          "name": "Update Member Status",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{librarianToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"membershipStatus\": \"active\",\n  \"borrowLimit\": 5\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/members/{{memberId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "members", "{{memberId}}", "status"]
            }
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "List Notifications",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data.notifications.length) {",
                  "  pm.collectionVariables.set('notificationId', json.data.notifications[0]._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{memberToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/notifications",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "notifications"]
            }
          }
        },
        {
          "name": "Mark Notification Read",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{memberToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/api/v1/notifications/{{notificationId}}/read",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "notifications", "{{notificationId}}", "read"]
            }
          }
        }
      ]
    },
    {
      "name": "Reports",
      "item": [
